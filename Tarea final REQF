\section{Sección III: Programación Shell (Bash Scripting)}

Bash permite automatizar tareas combinando comandos con estructuras de programación: variables, condicionales, bucles y funciones.

\subsection*{Estructura básica}

\begin{lstlisting}
#!/bin/bash
echo "Hola Mundo"
\end{lstlisting}

\begin{lstlisting}
#!/bin/bash
set -e
echo "Script profesional"
\end{lstlisting}

\subsection*{If - Else}

\begin{lstlisting}
if [ -f archivo.txt ]; then
 echo "Existe"
else
 echo "No existe"
fi
\end{lstlisting}

\begin{lstlisting}
if [[ $1 -gt 10 ]]; then
 echo "Mayor que 10"
fi
\end{lstlisting}

\subsection*{For}

\begin{lstlisting}
for i in {1..5}; do
 echo $i
done
\end{lstlisting}

\begin{lstlisting}
for file in *.txt; do
 echo $file
done
\end{lstlisting}

\subsection*{While}

\begin{lstlisting}
contador=1
while [ $contador -le 5 ]; do
 echo $contador
 ((contador++))
done
\end{lstlisting}

\begin{lstlisting}
while read linea; do
 echo $linea
done < archivo.txt
\end{lstlisting}

\subsection*{Script Profesional de Backup}

\begin{lstlisting}
#!/bin/bash
DESTINO="/backup"
ORIGEN="/home/usuario/docs"
FECHA=$(date +%Y-%m-%d)

mkdir -p $DESTINO
tar -czf $DESTINO/backup_$FECHA.tar.gz $ORIGEN

if [ $? -eq 0 ]; then
 echo "Backup exitoso"
else
 echo "Error en backup" >&2
fi
\end{lstlisting}

