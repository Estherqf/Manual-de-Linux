\section{Sección IV: Diagnóstico de Errores}

\begin{longtable}{|p{4cm}|p{5cm}|p{5cm}|}
\hline
\textbf{Error} & \textbf{Causa} & \textbf{Solución} \\ \hline
Permission denied & Falta permisos & chmod o sudo \\ \hline
Command not found & PATH incorrecto & export PATH \\ \hline
No such file & Ruta errónea & Verificar con ls \\ \hline
Directory not empty & Uso incorrecto de rmdir & rm -r \\ \hline
Bad interpreter & Shebang incorrecto & dos2unix o revisar #! \\ \hline
Out of memory & Proceso excesivo & top + kill \\ \hline
Connection refused & Servicio detenido & systemctl start \\ \hline
\end{longtable}

